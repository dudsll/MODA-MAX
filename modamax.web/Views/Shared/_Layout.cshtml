<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ModaMax</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/modamax.web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <div class="container-fluid topbar-content">
                <a class="brand-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">M</span>
                    <span>
                        <strong>ModaMax</strong>
                        <small>Sistema de gestao</small>
                    </span>
                </a>

                <nav class="main-nav">
                    <a asp-controller="Home" asp-action="Index">Dashboard</a>
                    <a asp-controller="Produto" asp-action="Index">Produtos</a>
                    <a asp-controller="Cliente" asp-action="Index">Clientes</a>
                </nav>
            </div>
        </header>

        <main class="container py-4">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
