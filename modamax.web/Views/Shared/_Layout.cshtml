@using Microsoft.AspNetCore.Http
@{
    var usuarioNome = Context.Session.GetString("UsuarioNome");
    var usuarioNivel = Context.Session.GetString("UsuarioNivel");
    var logado = !string.IsNullOrWhiteSpace(usuarioNome);
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ModaMax</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/modamax.web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <div class="container-fluid topbar-content">
                <a class="brand-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">M</span>
                    <span>
                        <strong>ModaMax</strong>
                        <small>Sistema de gestao</small>
                    </span>
                </a>

                <nav class="main-nav">
                    @if (logado)
                    {
                        <a asp-controller="Home" asp-action="Index">Dashboard</a>
                        <a asp-controller="Produto" asp-action="Index">Produtos</a>
                        <a asp-controller="Categoria" asp-action="Index">Categorias</a>
                        <a asp-controller="Cliente" asp-action="Index">Clientes</a>
                        <a asp-controller="Pedido" asp-action="Index">Pedidos</a>
                        <a asp-controller="Pedido" asp-action="Historico">Historico</a>
                        <a asp-controller="Relatorio" asp-action="Index">Relatorios</a>

                        @if (usuarioNivel == "Estrategico")
                        {
                            <a asp-controller="Usuario" asp-action="Index">Usuarios</a>
                            <a asp-controller="Log" asp-action="Index">Logs</a>
                        }
                    }
                </nav>

                <div class="user-pill">
                    @if (logado)
                    {
                        <span>@usuarioNome (@usuarioNivel)</span>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Account" asp-action="Logout">Sair</a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">Entrar</a>
                    }
                </div>
            </div>
        </header>

        <main class="container py-4">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
