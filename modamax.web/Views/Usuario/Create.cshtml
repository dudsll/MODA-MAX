@model modamax.web.Models.Usuario
@{ ViewData["Title"] = "Novo usuario"; }
<div class="page-header"><div><p class="section-kicker">Seguranca</p><h1>Novo usuario</h1></div><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div>
<div class="content-card form-card"><form asp-action="Create" class="row g-3"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-6"><label asp-for="Nome" class="form-label"></label><input asp-for="Nome" class="form-control" /></div><div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div><div class="col-md-6"><label asp-for="Senha" class="form-label"></label><input asp-for="Senha" class="form-control" /></div><div class="col-md-6"><label asp-for="Nivel" class="form-label"></label><select asp-for="Nivel" class="form-select"><option>Estrategico</option><option>Tatico</option><option>Operacional</option></select></div><div class="col-12"><button class="btn btn-primary" type="submit">Salvar</button></div></form></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
