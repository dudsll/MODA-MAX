@model modamax.web.Models.Categoria
@{ ViewData["Title"] = "Editar categoria"; }
<div class="page-header"><div><p class="section-kicker">Cadastros</p><h1>Editar categoria</h1></div><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div>
<div class="content-card form-card"><form asp-action="Edit" class="row g-3"><div asp-validation-summary="ModelOnly" class="text-danger"></div><input type="hidden" asp-for="IdCategoria" /><div class="col-md-6"><label asp-for="Nome" class="form-label"></label><input asp-for="Nome" class="form-control" /><span asp-validation-for="Nome" class="text-danger"></span></div><div class="col-12"><button class="btn btn-primary" type="submit">Salvar alteracoes</button></div></form></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
