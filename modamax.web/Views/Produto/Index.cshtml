@model IEnumerable<modamax.web.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<div class="page-header">
    <div>
        <p class="section-kicker">Cadastros</p>
        <h1>Produtos</h1>
        <p class="page-copy">Controle o catalogo da loja com informacoes de estoque, categoria e fornecedor.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Novo produto</a>
</div>

<div class="content-card">
    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Busca</label>
            <input type="text" name="busca" value="@ViewBag.Busca" class="form-control" placeholder="Nome ou codigo" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Categoria</label>
            <select name="categoriaId" asp-items="ViewBag.CategoriasFiltro" class="form-select">
                <option value="">Todas</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Tamanho</label>
            <input type="text" name="tamanho" value="@ViewBag.Tamanho" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Disponibilidade</label>
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" name="somenteDisponiveis" value="true" @(ViewBag.SomenteDisponiveis ? "checked" : "") />
                <label class="form-check-label">Apenas em estoque</label>
            </div>
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-modern align-middle">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.IdProduto)</th>
                    <th>@Html.DisplayNameFor(model => model.Nome)</th>
                    <th>@Html.DisplayNameFor(model => model.Categoria)</th>
                    <th>@Html.DisplayNameFor(model => model.Fornecedor)</th>
                    <th>@Html.DisplayNameFor(model => model.Preco)</th>
                    <th>@Html.DisplayNameFor(model => model.Estoque)</th>
                    <th class="text-end">Acoes</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdProduto</td>
                    <td>@item.Nome</td>
                    <td>@item.Categoria?.Nome</td>
                    <td>@item.Fornecedor?.Nome</td>
                    <td>@item.Preco.ToString("C")</td>
                    <td>@item.Estoque</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.IdProduto">Editar</a> |
                        <a asp-action="Details" asp-route-id="@item.IdProduto">Detalhes</a> |
                        <a asp-action="Delete" asp-route-id="@item.IdProduto">Excluir</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
