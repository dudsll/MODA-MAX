@model modamax.web.Models.Produto

@{
    ViewData["Title"] = "Detalhes do produto";
}

<div class="page-header">
    <div>
        <p class="section-kicker">Cadastros</p>
        <h1>@Model.Nome</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.IdProduto">Editar</a>
    </div>
</div>

<div class="content-card details-card">
    <dl class="row mb-0">
        <dt class="col-sm-3">Codigo</dt>
        <dd class="col-sm-9">@Model.IdProduto</dd>

        <dt class="col-sm-3">Descricao</dt>
        <dd class="col-sm-9">@Model.Descricao</dd>

        <dt class="col-sm-3">Tamanho</dt>
        <dd class="col-sm-9">@Model.Tamanho</dd>

        <dt class="col-sm-3">Cor</dt>
        <dd class="col-sm-9">@Model.Cor</dd>

        <dt class="col-sm-3">Categoria</dt>
        <dd class="col-sm-9">@Model.Categoria?.Nome</dd>

        <dt class="col-sm-3">Fornecedor</dt>
        <dd class="col-sm-9">@Model.Fornecedor?.Nome</dd>

        <dt class="col-sm-3">Preco</dt>
        <dd class="col-sm-9">@Model.Preco.ToString("C")</dd>

        <dt class="col-sm-3">Estoque</dt>
        <dd class="col-sm-9">@Model.Estoque</dd>
    </dl>
</div>
