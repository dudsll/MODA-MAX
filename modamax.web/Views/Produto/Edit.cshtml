@model modamax.web.Models.Produto

@{
    ViewData["Title"] = "Editar produto";
}

<div class="page-header">
    <div>
        <p class="section-kicker">Cadastros</p>
        <h1>Editar produto</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
</div>

<div class="content-card form-card">
    <form asp-action="Edit" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="IdProduto" />

        <div class="col-md-6">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Preco" class="form-label"></label>
            <input asp-for="Preco" class="form-control" />
            <span asp-validation-for="Preco" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Estoque" class="form-label"></label>
            <input asp-for="Estoque" class="form-control" />
            <span asp-validation-for="Estoque" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Descricao" class="form-label"></label>
            <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Descricao" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Tamanho" class="form-label"></label>
            <input asp-for="Tamanho" class="form-control" />
            <span asp-validation-for="Tamanho" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Cor" class="form-label"></label>
            <input asp-for="Cor" class="form-control" />
            <span asp-validation-for="Cor" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="IdCategoria" class="form-label"></label>
            <select asp-for="IdCategoria" asp-items="ViewBag.Categorias" class="form-select"></select>
            <span asp-validation-for="IdCategoria" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="IdFornecedor" class="form-label"></label>
            <select asp-for="IdFornecedor" asp-items="ViewBag.Fornecedores" class="form-select"></select>
            <span asp-validation-for="IdFornecedor" class="text-danger"></span>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Salvar alteracoes</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
