@model modamax.web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-shell">
    <div class="content-card auth-card">
        <p class="section-kicker">Acesso ao sistema</p>
        <h1>Entrar na ModaMax</h1>
        <form asp-action="Login" class="row g-3 mt-2">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="col-12">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Senha" class="form-label"></label>
                <input asp-for="Senha" class="form-control" />
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Entrar</button>
                <a class="btn btn-outline-secondary" asp-action="RecuperarSenha">Recuperar senha</a>
            </div>
        </form>
        @if (TempData["Mensagem"] != null)
        {
            <div class="alert alert-success mt-3">@TempData["Mensagem"]</div>
        }
        <div class="mt-3 small text-muted">
            Acessos de exemplo: `estrategico@modamax.com`, `tatico@modamax.com`, `operacional@modamax.com` com senha `123456`.
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
