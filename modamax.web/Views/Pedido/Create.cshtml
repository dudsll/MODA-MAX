@model modamax.web.ViewModels.PedidoFormViewModel
@{ ViewData["Title"] = "Novo pedido"; }
<div class="page-header"><div><p class="section-kicker">Vendas</p><h1>Novo pedido</h1></div><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div>
<div class="content-card form-card"><form asp-action="Create" class="row g-3"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-4"><label asp-for="IdCliente" class="form-label"></label><select asp-for="IdCliente" class="form-select">@foreach (var cliente in Model.Clientes){<option value="@cliente.IdCliente">@cliente.Nome</option>}</select></div><div class="col-md-4"><label asp-for="IdProduto" class="form-label"></label><select asp-for="IdProduto" class="form-select">@foreach (var produto in Model.Produtos){<option value="@produto.IdProduto">@produto.Nome (@produto.Estoque em estoque)</option>}</select></div><div class="col-md-4"><label asp-for="DataPedido" class="form-label"></label><input asp-for="DataPedido" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="TiposVenda" class="form-label"></label><select asp-for="TiposVenda" class="form-select"><option>Varejo</option><option>Atacado</option></select></div><div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" class="form-select"><option>Finalizado</option><option>Em separacao</option><option>Cancelado</option></select></div><div class="col-md-3"><label asp-for="Quantidade" class="form-label"></label><input asp-for="Quantidade" class="form-control" /></div><div class="col-md-3"><label asp-for="Desconto" class="form-label"></label><input asp-for="Desconto" class="form-control" /></div><div class="col-12"><button class="btn btn-primary" type="submit">Salvar pedido</button></div></form></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
