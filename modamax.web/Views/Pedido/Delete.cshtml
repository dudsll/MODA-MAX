@model modamax.web.Models.Pedido
@{ ViewData["Title"] = "Excluir pedido"; }
<div class="page-header"><div><p class="section-kicker">Vendas</p><h1>Excluir pedido</h1></div><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a></div>
<div class="content-card details-card"><p>Confirme a exclusao do pedido <strong>#@Model.IdPedido</strong> de <strong>@Model.Cliente?.Nome</strong>.</p><form asp-action="Delete" asp-route-id="@Model.IdPedido"><button class="btn btn-danger" type="submit">Excluir</button></form></div>
