@model modamax.web.Models.Pedido
@{ ViewData["Title"] = "Detalhes do pedido"; }
<div class="page-header"><div><p class="section-kicker">Vendas</p><h1>Pedido #@Model.IdPedido</h1></div><div class="header-actions"><a class="btn btn-outline-secondary" asp-action="Index">Voltar</a><a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.IdPedido">Editar</a></div></div>
<div class="content-grid"><article class="content-card details-card"><dl class="row mb-0"><dt class="col-sm-4">Cliente</dt><dd class="col-sm-8">@Model.Cliente?.Nome</dd><dt class="col-sm-4">Data</dt><dd class="col-sm-8">@Model.DataPedido.ToString("dd/MM/yyyy")</dd><dt class="col-sm-4">Tipo</dt><dd class="col-sm-8">@Model.TiposVenda</dd><dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Status</dd><dt class="col-sm-4">Valor total</dt><dd class="col-sm-8">@Model.ValorTotal.ToString("C")</dd></dl></article><article class="content-card"><h2>Itens do pedido</h2><div class="table-responsive"><table class="table table-modern"><thead><tr><th>Produto</th><th>Qtd</th><th>Preco unit.</th><th>Desconto</th></tr></thead><tbody>@foreach (var item in Model.Itens){<tr><td>@item.Produto?.Nome</td><td>@item.Quantidade</td><td>@item.PrecoUnitario.ToString("C")</td><td>@item.Desconto.ToString("C")</td></tr>}</tbody></table></div>@if (Model.Status != "Cancelado"){<form asp-action="Cancelar" method="post" asp-route-id="@Model.IdPedido"><button class="btn btn-outline-danger" type="submit">Cancelar pedido</button></form>}</article></div>
